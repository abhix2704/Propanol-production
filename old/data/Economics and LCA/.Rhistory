a
# library
library(tidyverse)
library(ggrepel)
library(readxl)
library(paletteer)
library(gridExtra)
data = read_excel("Economics plot data.xlsx", sheet = 1)
colors <- c("#da5552","#f99a5f","#7371fc","#60d394","#ee839f","#9bf6ff",
"#fec89a")
cumFeed = read_excel("Economics plot data.xlsx", sheet = 2)
cumOPEX = read_excel("Economics plot data.xlsx", sheet = 3)
cumCAPEX = read_excel("Economics plot data.xlsx", sheet = 4)
totalError = read_excel("Economics plot data.xlsx", sheet = 5)
# Stacked
p <- ggplot(data = data)
p <- p + geom_bar(aes(fill = fct_inorder(Category), x = Value, y  = fct_inorder(Process)),
position = position_stack(reverse = TRUE), stat = "identity", width = 0.4, color = "black")
p <- p + geom_vline(xintercept = 0, size = 1, color = "black")
p <- p + geom_point(data = cumFeed, aes(y = yCoordinate, x = Value), size = 4, shape = 24, fill = "#4300ed")
p <- p + geom_point(data = cumOPEX, aes(y = yCoordinate, x = Value), size = 4, shape = 24, fill = "#00d37b")
p <- p + geom_point(data = cumCAPEX, aes(y = yCoordinate, x = Value), size = 4, shape = 24, fill = "#ed0062")
p <- p + geom_point(data = totalError, aes(y = yCoordinate, x = Total), size = 4, shape = 18)
p <- p + geom_errorbarh(data = totalError, aes(y = yCoordinate, xmin = Total - Low, xmax = Total + High),
height = 0.1, size = 1)
p <- p + theme(panel.grid.major = element_blank(), panel.grid.minor = element_blank(),
panel.background = element_blank(), axis.line = element_line(colour = "black"))
p <- p + theme(panel.border = element_rect(colour = "black", fill=NA, size=2))
p <- p + theme(axis.title.y = element_blank())
p <- p + theme(legend.title = element_blank())
p <- p + labs(x = expression("Production cost [$/t propanol]"))
p <- p + theme(text = element_text(size = 15))
p <- p + scale_fill_manual(values = colors)
p <- p + scale_x_continuous(expand = c(0, 0), limits = c(0, 5000))
p
#CAPEX
CAPEXColors <- paletteer_c("grDevices::RdYlBu", 6)
BAUCAPEXD = read_excel("Economics plot data.xlsx", sheet = 6)
GreenCAPEXD = read_excel("Economics plot data.xlsx", sheet = 7)
BAUCAPEXData <- BAUCAPEXD %>%
mutate(csum = rev(cumsum(rev(Labels))),
pos = Labels/2 + lead(csum, 1),
pos = if_else(is.na(pos), Labels/2, pos))
p2 <- ggplot(BAUCAPEXData, aes(x = "" , y = Labels, fill = fct_inorder(Category)))
p2 <- p2 + geom_col(size = 1, width = 1, color = 1)
p2 <- p2 + coord_polar(theta = "y")
p2 <- p2 + scale_fill_brewer(palette = "Pastel1")
p2 <- p2 + geom_label_repel(data = BAUCAPEXData,
aes(y = pos, label = paste0(sprintf("%0.1f", round(Labels, digits = 2)), "%")),
size = 4.5, nudge_x = 0.5, show.legend = FALSE)
p2 <- p2 + guides(fill = guide_legend(title = "Category"))
p2 <- p2 + theme_void()
p2 <- p2 + theme(legend.title = element_blank())
p2 <- p2 + theme(text = element_text(size = 15))
GreenCAPEXData <- GreenCAPEXD %>%
mutate(csum = rev(cumsum(rev(Labels))),
pos = Labels/2 + lead(csum, 1),
pos = if_else(is.na(pos), Labels/2, pos))
p3 <- ggplot(GreenCAPEXData, aes(x = "" , y = Labels, fill = fct_inorder(Category)))
p3 <- p3 + geom_col(size = 1, width = 1, color = 1)
p3 <- p3 + coord_polar(theta = "y")
p3 <- p3 + scale_fill_brewer(palette = "Pastel1")
p3 <- p3 + geom_label_repel(data = GreenCAPEXData,
aes(y = pos, label = paste0(sprintf("%0.1f", round(Labels, digits = 2)), "%")),
size = 4.5, nudge_x = 0.5, show.legend = FALSE)
p3 <- p3 + guides(fill = guide_legend(title = "Category"))
p3 <- p3 + theme_void()
p3 <- p3 + theme(legend.title = element_blank())
p3 <- p3 + theme(text = element_text(size = 15))
grid.arrange(p2, p3, ncol = 2)
p
