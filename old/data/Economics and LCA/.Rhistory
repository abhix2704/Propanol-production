data = read_excel("Economics plot data.xlsx", sheet = 1)
colors <- c("#da5552","#f99a5f","#7371fc","#60d394","#ee839f","#9bf6ff",
"#fec89a")
cumFeed = read_excel("Economics plot data.xlsx", sheet = 2)
cumOPEX = read_excel("Economics plot data.xlsx", sheet = 3)
cumCAPEX = read_excel("Economics plot data.xlsx", sheet = 4)
totalError = read_excel("Economics plot data.xlsx", sheet = 5)
# Stacked
p <- ggplot(data = data)
p <- p + geom_bar(aes(fill = fct_inorder(Category), x = Value, y  = fct_inorder(Process)),
position = position_stack(reverse = TRUE), stat = "identity", width = 0.4, color = "black")
p <- p + geom_vline(xintercept = 0, size = 1, color = "black")
p <- p + geom_point(data = cumFeed, aes(y = yCoordinate, x = Value), size = 4, shape = 24, fill = "#4300ed")
