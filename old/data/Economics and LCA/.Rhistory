p <- p + geom_point(data = totalError, aes(y = yCoordinate, x = Total), size = 4, shape = 18)
p <- p + geom_errorbarh(data = totalError, aes(y = yCoordinate, xmin = Total - Low, xmax = Total + High),
height = 0.1, size = 1)
p <- p + theme(panel.grid.major = element_blank(), panel.grid.minor = element_blank(),
panel.background = element_blank(), axis.line = element_line(colour = "black"))
p <- p + theme(panel.border = element_rect(colour = "black", fill=NA, size=2))
